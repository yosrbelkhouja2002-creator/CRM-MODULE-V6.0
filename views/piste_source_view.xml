<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- DONNÉES : Régions géographiques (noupdate)    -->
    <!-- ============================================== -->
    <data noupdate="1">
        <record id="region_europe" model="piste.region">
            <field name="name">Europe</field>
            <field name="country_group_name">Europe</field>
        </record>
        <record id="region_afrique" model="piste.region">
            <field name="name">Afrique</field>
            <field name="country_group_name">Africa</field>
        </record>
        <record id="region_amerique_nord" model="piste.region">
            <field name="name">Amérique du Nord</field>
            <field name="country_group_name">America</field>
        </record>
        <record id="region_amerique_sud" model="piste.region">
            <field name="name">Amérique du Sud</field>
            <field name="country_group_name">America</field>
        </record>
        <record id="region_asie" model="piste.region">
            <field name="name">Asie</field>
            <field name="country_group_name">Asia</field>
        </record>
        <record id="region_oceanie" model="piste.region">
            <field name="name">Océanie</field>
            <field name="country_group_name">Oceania</field>
        </record>
        <record id="region_moyen_orient" model="piste.region">
            <field name="name">Moyen-Orient</field>
            <field name="country_group_name">Middle East</field>
        </record>
        <record id="region_monde" model="piste.region">
            <field name="name">Monde entier</field>
            <field name="country_group_name"></field>
        </record>
    </data>

    <!-- ============================================== -->
    <!-- ACTIONS GLOBALES (conservées pour le menu)    -->
    <!-- ============================================== -->

    <record id="action_pistes_trouvees" model="ir.actions.act_window">
        <field name="name">Pistes trouvées</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('type','=','lead')]</field>
        <field name="context">{'default_type': 'lead'}</field>
    </record>

    <record id="action_pistes_validees" model="ir.actions.act_window">
        <field name="name">Pistes validées</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('type','=','opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <record id="action_stats" model="ir.actions.act_window">
        <field name="name">Statistiques</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <record id="action_piste_keyword" model="ir.actions.act_window">
        <field name="name">Mots-clés</field>
        <field name="res_model">piste.keyword</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_piste_keyword_tree" model="ir.ui.view">
        <field name="name">piste.keyword.tree</field>
        <field name="model">piste.keyword</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name" string="Mot-clé"/>
            </tree>
        </field>
    </record>

    <menuitem id="menu_piste_keyword"
              name="Mots-clés de veille"
              parent="crm.crm_menu_config"
              action="action_piste_keyword"
              sequence="99"/>

    <!-- ============================================== -->
    <!-- VUE PRINCIPALE : Fiche Veille commerciale     -->
    <!-- ============================================== -->

    <record id="view_piste_source_form" model="ir.ui.view">
        <field name="name">piste.source.form</field>
        <field name="model">piste.source</field>
        <field name="arch" type="xml">
            <form string="Veille commerciale">
                <header>
                    <button name="action_run_scrape"
                            type="object"
                            string="Lancer scraping N8N"
                            class="btn-primary"
                            help="Envoie la configuration à N8N pour scraping réel"/>
                </header>

                <sheet>
                    <!-- ===== SMART BUTTONS ===== -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_crm_leads"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-inbox">
                            <field name="crm_lead_count"
                                   widget="statinfo"
                                   string="Pistes trouvées"/>
                        </button>
                    </div>

                    <!-- TITRE -->
                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   string="Nom de la veille"
                                   placeholder="Ex : Projets Odoo – Développement"/>
                        </h1>
                    </div>

                    <!-- CONFIGURATION PRINCIPALE -->
                    <group>
                        <group>
                            <field name="description"
                                   string="Description"
                                   widget="text"
                                   placeholder="Objectif de cette veille..."/>
                        </group>
                        <group>
                            <field name="keywords_required_ids"
                                   string="Mots-clés requis"
                                   widget="many2many_tags"
                                   placeholder="Sélectionnez ou ajoutez des mots-clés"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="geo_zone_region_ids"
                                   string="Régions ciblées"
                                   widget="many2many_tags"
                                   placeholder="Sélectionnez une ou plusieurs régions"/>
                        </group>
                        <group>
                            <field name="geo_zone_allowed_country_ids" invisible="1"/>
                            <field name="geo_zones"
                                   string="Pays ciblés"
                                   widget="many2many_tags"
                                   placeholder="Sélectionnez un ou plusieurs pays"
                                   domain="[('id', 'in', geo_zone_allowed_country_ids)]"/>
                        </group>
                    </group>

                    <!-- NOTEBOOK -->
                    <notebook>

                        <!-- ONGLET 1 : Plateformes -->
                        <page string="Plateformes">
                            <group>
                                <group>
                                    <field name="platform_achatpublic"/>
                                    <field name="platform_francemarches"/>
                                    <field name="platform_awsolutions"/>
                                    <field name="platform_doubletrade"/>
                                </group>
                                <group>
                                    <field name="platform_marchespublics"/>
                                    <field name="platform_marchessecurise"/>
                                    <field name="platform_boamp"/>
                                </group>
                            </group>
                        </page>

                        <!-- ONGLET 2 : Planification -->
                        <page string="Planification">
                            <group>
                                <field name="automation_type" widget="radio"/>
                            </group>
                            <group invisible="automation_type == 'manual'">
                                <group string="Fréquence d'exécution">
                                    <field name="auto_frequency"/>
                                    <field name="auto_time"
                                           string="Heure d'exécution"
                                           invisible="auto_frequency == 'custom' and custom_interval_unit == 'hours'"/>
                                </group>
                                <group string="Personnalisation"
                                       invisible="auto_frequency != 'custom'">
                                    <field name="custom_interval" string="Répéter tous les"/>
                                    <field name="custom_interval_unit" string="Unité"/>
                                </group>
                                <group string="Période d'activité">
                                    <field name="auto_date_start"/>
                                    <field name="auto_date_end"/>
                                </group>
                            </group>
                        </page>

                        <!-- ONGLET 3 : Informations supplémentaires -->
                        <page string="Informations supplémentaires">
                            <group>
                                <group>
                                    <separator string="Notifications" colspan="2"/>
                                    <!-- Notification Odoo en premier -->
                                    <field name="notify_odoo"/>
                                    <!-- Notification email + destinataires en dessous -->
                                    <field name="notify_email"/>
                                    <field name="notify_email_ids"
                                           string="Emails des destinataires"
                                           widget="many2many_tags"
                                           invisible="not notify_email"/>
                                    <separator string="Budget" colspan="2"/>
                                    <field name="budget_min"/>
                                    <field name="budget_max"/>
                                </group>
                                <group>
                                    <separator string="Durée du contrat" colspan="2"/>
                                    <field name="duration_short"/>
                                    <field name="duration_medium"/>
                                    <field name="duration_long"/>
                                    <separator string="Type de client" colspan="2"/>
                                    <field name="client_pme"/>
                                    <field name="client_large"/>
                                </group>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================== -->
    <!-- ACTION PRINCIPALE DU MENU VEILLE              -->
    <!-- ============================================== -->
    <record id="action_opportunity_workflow" model="ir.actions.act_window">
        <field name="name">Veille commerciale</field>
        <field name="res_model">piste.source</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>