<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ✅ Ajouter le champ "Veille commerciale" dans l'onglet Marketing du lead CRM -->
    <record id="crm_lead_form_inherit_piste_source" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.piste.source</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm_lead_code_update.view_crm_lead_form_inherit_type_contact"/>
        <field name="priority">25</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='source_id']" position="after">
                <field name="piste_source_id" string="Veille commerciale" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>