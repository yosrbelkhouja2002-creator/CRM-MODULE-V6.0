<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- ACTIONS                                            -->
    <!-- ============================================== -->

    <!-- Action : Créer une nouvelle recherche (veille) -->
    <record id="action_create_source" model="ir.actions.act_window">
        <field name="name">Créer une recherche</field>
        <field name="res_model">piste.source</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_piste_source_form"/>
        <field name="target">new</field>
    </record>

    <!-- Action : Pistes trouvées (leads) - corrigée -->
    <record id="action_pistes_trouvees" model="ir.actions.act_window">
        <field name="name">Pistes trouvées</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('type','=','lead')]</field>
        <field name="context">{
            'default_type': 'lead',
        }</field>
        <!-- IMPORTANT : on n'utilise PAS de ref invalide ici pour éviter le crash -->
        <!-- On laisse la vue par défaut d'Odoo (crm.crm_case_tree_view_oppor) -->
        <!-- Quand ta vue personnalisée sera prête, tu pourras ajouter : -->
        <!-- <field name="view_id" ref="ton_vrai_module.view_pistes_trouvees_tree"/> -->
    </record>

    <!-- Action : Pistes validées (opportunités) -->
    <record id="action_pistes_validees" model="ir.actions.act_window">
        <field name="name">Pistes validées</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('type','=','opportunity')]</field>
        <field name="context">{
            'default_type': 'opportunity',
            'default_name': 'Opp. validée - ' + str(fields.Datetime.now().strftime('%d/%m/%Y %H:%M'))
        }</field>
    </record>

    <!-- Action : Nouvelle opportunité -->
    <record id="action_new_opportunity" model="ir.actions.act_window">
        <field name="name">Nouvelle opportunité</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{
            'default_type': 'opportunity',
            'default_name': 'Nouvelle opportunité - ' + str(fields.Datetime.now().strftime('%d/%m/%Y %H:%M'))
        }</field>
    </record>

    <!-- Action : Statistiques -->
    <record id="action_stats" model="ir.actions.act_window">
        <field name="name">Statistiques</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <!-- ============================================== -->
    <!-- DASHBOARD VIEW - propre et sans risque       -->
    <!-- ============================================== -->

    <record id="view_opportunity_workflow_dashboard" model="ir.ui.view">
        <field name="name">opportunity.workflow.dashboard</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <form string="Workflow de prospection" create="false" edit="false">
                <sheet>
                    <div class="oe_title mb32">
                        <h1 style="text-align:center; color:#875A7B; margin-left:120px;">
                            Workflow de prospection
                        </h1>
                    </div>

                    <separator string="PROCESSUS" style="margin-bottom:30px;"/>

                    <div class="d-flex justify-content-center align-items-center"
                         style="gap:18px; flex-wrap:wrap; margin:30px 0;">

                        <!-- CARD 1 : Recherche -->
                        <button name="%(action_create_source)d" type="action"
                                style="width:160px;height:140px;border-radius:18px;border:1px solid #eee;background:white;box-shadow:0 8px 20px rgba(0,0,0,.08);transition:.25s;cursor:pointer;"
                                onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 30px rgba(0,0,0,.15)'"
                                onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 20px rgba(0,0,0,.08)'">
                            <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;height:100%;text-align:center;">
                                <i class="fa fa-search" style="font-size:38px;color:#875A7B;margin-bottom:10px;"/>
                                <strong style="min-height:36px;display:flex;align-items:center;">Recherche</strong>
                            </div>
                        </button>

                        <i class="fa fa-arrow-right" style="font-size:32px;color:#bbb"/>

                        <!-- CARD 2 : Pistes trouvées -->
                        <button name="%(action_pistes_trouvees)d" type="action"
                                style="width:160px;height:140px;border-radius:18px;border:1px solid #eee;background:white;box-shadow:0 8px 20px rgba(0,0,0,.08);transition:.25s;cursor:pointer;"
                                onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 30px rgba(0,0,0,.15)'"
                                onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 20px rgba(0,0,0,.08)'">
                            <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;height:100%;text-align:center;">
                                <i class="fa fa-inbox" style="font-size:38px;color:#17a2b8;margin-bottom:10px;"/>
                                <strong style="min-height:36px;display:flex;align-items:center;">Pistes<br/>trouvées</strong>
                            </div>
                        </button>

                        <i class="fa fa-arrow-right" style="font-size:32px;color:#bbb"/>

                        <!-- CARD 3 : Pistes validées -->
                        <button name="%(action_pistes_validees)d" type="action"
                                style="width:160px;height:140px;border-radius:18px;border:1px solid #eee;background:white;box-shadow:0 8px 20px rgba(0,0,0,.08);transition:.25s;cursor:pointer;"
                                onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 30px rgba(0,0,0,.15)'"
                                onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 20px rgba(0,0,0,.08)'">
                            <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;height:100%;text-align:center;">
                                <i class="fa fa-check-circle" style="font-size:38px;color:#28a745;margin-bottom:10px;"/>
                                <strong style="min-height:36px;display:flex;align-items:center;">Pistes<br/>validées</strong>
                            </div>
                        </button>

                        <i class="fa fa-arrow-right" style="font-size:32px;color:#bbb"/>

                        <!-- CARD 4 : Nouvelle opportunité -->
                        <button name="%(action_new_opportunity)d" type="action"
                                style="width:160px;height:140px;border-radius:18px;border:1px solid #eee;background:white;box-shadow:0 8px 20px rgba(0,0,0,.08);transition:.25s;cursor:pointer;"
                                onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 30px rgba(0,0,0,.15)'"
                                onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 20px rgba(0,0,0,.08)'">
                            <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;height:100%;text-align:center;">
                                <i class="fa fa-plus-circle" style="font-size:38px;color:#d9534f;margin-bottom:10px;"/>
                                <strong style="min-height:36px;display:flex;align-items:center;">Nouvelle<br/>opportunité</strong>
                            </div>
                        </button>

                        <i class="fa fa-arrow-right" style="font-size:32px;color:#bbb"/>

                        <!-- CARD 5 : Statistiques -->
                        <button name="%(action_stats)d" type="action"
                                style="width:160px;height:140px;border-radius:18px;border:1px solid #eee;background:white;box-shadow:0 8px 20px rgba(0,0,0,.08);transition:.25s;cursor:pointer;"
                                onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 30px rgba(0,0,0,.15)'"
                                onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 20px rgba(0,0,0,.08)'">
                            <div style="display:flex;flex-direction:column;justify-content:center;align-items:center;height:100%;text-align:center;">
                                <i class="fa fa-bar-chart" style="font-size:38px;color:#f0ad4e;margin-bottom:10px;"/>
                                <strong style="min-height:36px;display:flex;align-items:center;">Statistiques</strong>
                            </div>
                        </button>

                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action principale du menu -->
    <record id="action_opportunity_workflow" model="ir.actions.act_window">
        <field name="name">Opportunités</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_opportunity_workflow_dashboard"/>
    </record>

</odoo>